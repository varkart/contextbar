{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aicontextbar",
  "version": "0.7.0",
  "identifier": "com.varkart.aicontextbar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": ["https://github.com/varkart/agentbar/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "minimumSystemVersion": "13.0",
      "dmg": {
        "windowSize": { "width": 540, "height": 360 },
        "appPosition": { "x": 130, "y": 160 },
        "applicationFolderPosition": { "x": 410, "y": 160 }
      }
    }
  }
}
