# PostHog analytics (public token — safe to commit in normal projects, kept here for clarity)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error tracking (DSN is public — safe to commit)
VITE_SENTRY_DSN=

# Sentry source map upload (SECRET — never commit)
# Get from: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=contextbar
