{
  "name": "contextbar",
  "private": true,
  "version": "0.8.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "pkill -x contextbar 2>/dev/null; npm run tauri dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "concurrently --kill-others-on-fail -n js,rust -c cyan,yellow \"npm run test\" \"bash -c 'source $HOME/.cargo/env && cargo test --manifest-path src-tauri/Cargo.toml'\"",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:report": "playwright show-report playwright-report",
    "lint": "tsc --noEmit && eslint src --ext ts,tsx --max-warnings 0",
    "dmg": "npm run tauri build -- --bundles dmg && bash scripts/clean-dmg.sh"
  },
  "dependencies": {
    "@posthog/react": "^1.10.3",
    "@sentry/react": "^10.66.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "geist": "^1.7.2",
    "posthog-js": "^1.404.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.4.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.7",
    "webdriverio": "^9.27.2"
  }
}
